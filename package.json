{
  "name": "teslamate-scriptable-widget",
  "version": "0.1.0",
  "private": true,
  "description": "TeslaMate Scriptable widget with local Scriptable runtime tests.",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:scriptable": "node --test tests/scriptable-widget.test.js",
    "capture:widget": "node scripts/capture-real-widget.js --reload",
    "capture:widget:color": "node scripts/capture-real-widget.js --reload --full-color --prefix real-widget-color",
    "capture:iphone": "node scripts/capture-iphone-screen.js",
    "capture:iphone:mirror": "node scripts/capture-iphone-mirroring.js",
    "capture:iphone:mirror:widget": "node scripts/capture-iphone-mirroring.js --crop-widget --prefix iphone-mirroring-widget-source"
  },
  "engines": {
    "node": ">=20"
  }
}
